# ------------------------------------------------------------------
# Bite · 环境变量模板
# 拷贝为 .env.local 并填入真实值（.env.local 已在 .gitignore，不会被提交）
# ------------------------------------------------------------------

# --- Supabase（必须）-------------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 注：service_role key 当前代码未使用（写入全走 RLS + anon key），无需配置。
# 它能绕过所有 RLS，是最危险的 secret——没用到就别设，减少泄露面。
# SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini（推荐，App 默认 LLM · 真免费）---------------------
# https://aistudio.google.com/app/apikey
# 免费 tier 15 RPM / 1M TPM，跑个人 / 朋友 demo 够用
GEMINI_API_KEY=

# --- Google Cloud Maps Platform（必须）-----------------------------
# 需启用：Maps JavaScript API + Places API (New) + Geocoding API
# 建议加 HTTP referrer 限制 + 预算告警 $5
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Google Places 服务端 key（生产 referrer 限制场景必须）----------
# 服务端 fetchPlaceDetails（quick-add 确认页等）没有 Referer 头，若 NEXT_PUBLIC_ 那把
# 在 GCP 加了 HTTP referrer 限制，复用会被 Google 403：
#   "Requests from referer <empty> are blocked"
# 这把 key 要走另一种保护策略：
#   - GCP Console → Credentials → 新建 API key
#   - Application restrictions = None（关键，不能设 referrer）
#   - API restrictions = Places API (New) + Geocoding API（必要时）
#   - Billing → 预算告警 $5
# 不要带 NEXT_PUBLIC_ 前缀——这把只能留服务端，不要 bundle 进浏览器。
# dev 不填也行，代码会回退到 NEXT_PUBLIC_GOOGLE_MAPS_API_KEY（dev 用 key 通常未加 referrer）。
GOOGLE_PLACES_SERVER_KEY=

# --- App 公网地址（必须）-------------------------------------------
# 用于 OAuth 回调、Magic Link 重定向。
# 生产部署务必改为真实域名（否则邮件链接指 localhost，用户点了到不了线上站）。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- 可选 LLM provider（用户可在 /profile Settings 选 + 自带 key）------
# 这些都不填也行——用户用 Gemini 即可。配上就给所有用户多一个 provider 选项。
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# 阿里云 DashScope (Qwen)
DASHSCOPE_API_KEY=

# --- 可选 邮件（自家域名发件）---------------------------------------
# 当前代码用 Supabase 默认邮件，开发 / 小流量足够。
# 想要更可靠 + 自家域名发件：在 Supabase Auth → Email Settings 接 Resend / SendGrid
# SMTP。代码侧无需任何 env var。
