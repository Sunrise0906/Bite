# ------------------------------------------------------------------
# Bite · 环境变量模板
# 拷贝为 .env.local 并填入真实值（.env.local 已在 .gitignore，不会被提交）
# ------------------------------------------------------------------

# --- Supabase（必须）-------------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 注：service_role key 当前代码未使用（写入全走 RLS + anon key），无需配置。
# 它能绕过所有 RLS，是最危险的 secret——没用到就别设，减少泄露面。
# SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini（推荐，App 默认 LLM · 真免费）---------------------
# https://aistudio.google.com/app/apikey
# 免费 tier 15 RPM / 1M TPM，跑个人 / 朋友 demo 够用
GEMINI_API_KEY=

# --- Google Cloud Maps Platform（必须）-----------------------------
# 需启用：Maps JavaScript API + Places API (New) + Geocoding API
# 建议加 HTTP referrer 限制 + 预算告警 $5
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Google Places 服务端 key（生产 referrer 限制场景必须）----------
# 服务端 fetchPlaceDetails（quick-add 确认页等）没有 Referer 头，若 NEXT_PUBLIC_ 那把
# 在 GCP 加了 HTTP referrer 限制，复用会被 Google 403：
#   "Requests from referer <empty> are blocked"
# 这把 key 要走另一种保护策略：
#   - GCP Console → Credentials → 新建 API key
#   - Application restrictions = None（关键，不能设 referrer）
#   - API restrictions = Places API (New) + Geocoding API（必要时）
#   - Billing → 预算告警 $5
# 不要带 NEXT_PUBLIC_ 前缀——这把只能留服务端，不要 bundle 进浏览器。
# dev 不填也行，代码会回退到 NEXT_PUBLIC_GOOGLE_MAPS_API_KEY（dev 用 key 通常未加 referrer）。
GOOGLE_PLACES_SERVER_KEY=

# --- App 公网地址（必须）-------------------------------------------
# 用于 OAuth 回调、Magic Link 重定向。
# 生产部署务必改为真实域名（否则邮件链接指 localhost，用户点了到不了线上站）。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- 可选 LLM provider（用户可在 /profile Settings 选 + 自带 key）------
# 这些都不填也行——用户用 Gemini 即可。配上就给所有用户多一个 provider 选项。
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# 阿里云 DashScope (Qwen)
DASHSCOPE_API_KEY=

# --- 可选 设置加密（at-rest 防护 user_llm_settings.api_key）-----------
# 配上后，用户在 Settings 自带的 LLM api_key 会 AES-256-GCM 加密再落库（RLS 之外的纵深）。
# 不配则按明文存（行为同今天，不影响功能）。生成一串高熵随机值即可，例如：
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 注意：设了之后别再改/删——改了会导致已加密的 key 解不开（用户需在 Settings 重填）。
BITE_SETTINGS_SECRET=

# --- 可选 邮件通知（Resend，朋友推荐→邮件提醒收件人）-----------------
# 配上后，A 推荐一家店给 B 时会给 B 发一封「去收件箱看看」邮件，补齐协作闭环。
# 不配则静默跳过（推荐仍正常入 inbox，只是没有邮件提醒）。
#   1. resend.com 注册 → API Keys 建一把 re_... key
#   2. 验证一个发件域名（或先用 onboarding@resend.dev 测）
#   3. EMAIL_FROM 形如 "Bite <notify@yourdomain.com>"
# 注：这跟 Auth 的 Magic Link 邮件是两回事——登录邮件仍在 Supabase Auth → SMTP 配。
RESEND_API_KEY=
EMAIL_FROM=
